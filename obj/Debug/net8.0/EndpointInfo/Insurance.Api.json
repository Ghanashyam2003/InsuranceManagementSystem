  "components": {
    "schemas": {
      "AddressDto": {
        "required": [
          "addressLine1",
          "city",
          "pinCode",
          "state"
        ],
        "type": "object",
        "properties": {
          "addressLine1": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "addressLine2": {
            "maxLength": 200,
            "type": "string",
            "nullable": true
          },
          "city": {
            "maxLength": 100,
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "state": {
            "maxLength": 100,
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "pinCode": {
            "minLength": 1,
            "pattern": "^[1-9]{1}[0-9]{5}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "AgentRegisterDto": {
        "required": [
          "agentCode",
          "email",
          "firstName",
          "lastName",
          "mobileNumber"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "minLength": 1,
            "type": "string"
          },
          "lastName": {
            "minLength": 1,
            "type": "string"
          },
          "mobileNumber": {
            "minLength": 1,
            "type": "string",
            "format": "tel"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "agentCode": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CustomerProfileUpdateDto": {
        "required": [
          "aadhaarNumber",
          "firstName",
          "lastName",
          "panNumber"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "lastName": {
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "mobileNumber": {
            "type": "string",
            "format": "tel",
            "nullable": true
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "gender": {
            "type": "string",
            "nullable": true
          },
          "panNumber": {
            "minLength": 1,
            "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
            "type": "string"
          },
          "aadhaarNumber": {
            "minLength": 1,
            "pattern": "^[2-9]{1}[0-9]{11}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CustomerRegisterDto": {
        "required": [
          "aadhaarNumber",
          "email",
          "firstName",
          "lastName",
          "panNumber",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          },
          "firstName": {
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "lastName": {
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "mobileNumber": {
            "type": "string",
            "format": "tel",
            "nullable": true
          },
          "panNumber": {
            "minLength": 1,
            "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
            "type": "string"
          },
          "aadhaarNumber": {
            "minLength": 1,
            "pattern": "^[2-9]{1}[0-9]{11}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "NomineeDto": {
        "required": [
          "nomineeName",
          "relation",
          "sharePercentage"
        ],
        "type": "object",
        "properties": {
          "nomineeName": {
            "maxLength": 100,
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "relation": {
            "maxLength": 50,
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "sharePercentage": {
            "maximum": 100,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "Enter: Bearer {token}",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}